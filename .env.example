# ─── TMDB (Obrigatório) ───────────────────────────────────────────────────────
# Obtenha em: https://www.themoviedb.org/settings/api → "API Read Access Token"
# Mesmo token usado no dev (Vite proxy) e na Vercel (TMDB_READ_TOKEN server-side)
VITE_TMDB_READ_TOKEN=your_tmdb_read_access_token_here
VITE_TMDB_BASE_URL=https://api.themoviedb.org/3
VITE_TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p

# ─── Sentry (Opcional) ───────────────────────────────────────────────────────
VITE_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=tmdb-movies

# ─── Google Analytics 4 (Opcional) ──────────────────────────────────────────
VITE_GA_MEASUREMENT_ID=
