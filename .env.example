# ─────────────────────────────────────────────────────────────────────────────
# MovieDB — Sistema de Filmes com TMDB
# Copie este arquivo para .env e preencha com suas credenciais.
#
#   cp .env.example .env
#
# ⚠️  NUNCA suba o arquivo .env para o repositório — ele está no .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ─── TMDB API (Obrigatório) ───────────────────────────────────────────────────
# 1. Crie uma conta gratuita em: https://www.themoviedb.org/
# 2. Gere sua API Key em:        https://www.themoviedb.org/settings/api
# 3. Documentação:               https://developers.themoviedb.org/3
VITE_TMDB_API_KEY=your_tmdb_api_key_here
VITE_TMDB_BASE_URL=https://api.themoviedb.org/3
VITE_TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p

# ─── Sentry — Observabilidade e Monitoramento de Erros (Opcional) ────────────
# 1. Crie um projeto React em: https://sentry.io/
# 2. Copie o DSN em:           Settings → Projects → <seu projeto> → Client Keys
# 3. Gere um auth token em:    https://sentry.io/settings/account/api/auth-tokens/
# 4. Substitua <org> e <project> com os valores do seu workspace Sentry.
# Deixe em branco para desabilitar o Sentry.
VITE_SENTRY_DSN=https://1be36b5fec0c640a5a01952bfffc831e@o4511539104317440.ingest.us.sentry.io/4511539169460224
SENTRY_AUTH_TOKEN=
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=tmdb-movies

# ─── Google Analytics 4 (Opcional) ──────────────────────────────────────────
# 1. Crie uma propriedade GA4 em: https://analytics.google.com/
# 2. Vá em:  Admin → Data Streams → seu stream → Measurement ID
# 3. O formato é: G-XXXXXXXXXX
# Deixe em branco para desabilitar o Analytics.
VITE_GA_MEASUREMENT_ID=
